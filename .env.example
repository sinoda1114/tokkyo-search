# Turso (libSQL)
# turso db create tokko-search / turso db show tokko-search --url / turso db tokens create tokko-search
TURSO_DATABASE_URL=libsql://tokko-search-xxxx.turso.io
TURSO_AUTH_TOKEN=

# BigQuery（Google Patents Public Data の JP派生テーブル用）
# GCPプロジェクト作成 + BigQuery API有効化 + 課金有効化 + サービスアカウント作成
# (roles/bigquery.jobUser + patents_jp データセットへの dataViewer)
GCP_PROJECT_ID=
# サービスアカウントJSONキーを1行のbase64にエンコードして設定: base64 -i key.json | tr -d '\n'
GCP_SERVICE_ACCOUNT_KEY=
BQ_DATASET=patents_jp
BQ_MAX_BYTES_BILLED=53687091200

# Gemini（Google AI Studio → Get API key）
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# 特許庁 特許情報取得API（任意・申請中。未設定でも動作する）
JPO_API_USERNAME=
JPO_API_PASSWORD=

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# E2E（Playwright）テスト専用。"1" のときBigQuery/Geminiへの実呼び出しをせず固定フィクスチャを返す。
# 本番環境では絶対に設定しないこと（playwright.config.ts のwebServer.envでのみ設定される）。
MOCK_EXTERNAL_APIS=
